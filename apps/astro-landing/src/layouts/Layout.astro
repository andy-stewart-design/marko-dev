---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "astro-marko",
  description = "Marko 6 islands for Astro.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="https://fav.farm/🤙" />
  </head>
  <body>
    <nav>
      <span class="nav-brand">astro-marko</span>
      <a
        href="https://www.npmjs.com/package/@andystewartdesign/astro-marko"
        target="_blank"
        rel="noopener">npm ↗</a
      >
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        Built with <a href="https://markojs.com" target="_blank" rel="noopener"
          >Marko 6</a
        > and <a href="https://astro.build" target="_blank" rel="noopener"
          >Astro</a
        >
      </p>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --accent: #0d9488;
    --accent-bg: #f0fdfa;
    --bg: #ffffff;
    --text: #1e293b;
    --text-muted: #64748b;
    --border: #e2e8f0;
    --code-bg: #1e1e2e;
    --mono: ui-monospace, "Cascadia Code", "Fira Code", monospace;
  }

  html {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Nav ── */
  nav {
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  nav a {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  /* ── Main ── */
  main {
    flex: 1;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
    padding: 3.5rem 2rem 4rem;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  footer a {
    color: var(--accent);
    text-decoration: none;
  }

  footer a:hover {
    text-decoration: underline;
  }

  /* ── Prose ── */
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 0.875rem;
  }

  h2 {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.375rem;
  }

  p {
    margin-bottom: 1rem;
    color: var(--text);
  }

  a {
    color: var(--accent);
  }

  ul,
  ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  /* Inline code */
  :not(pre) > code {
    font-family: var(--mono);
    font-size: 0.875em;
    background: var(--accent-bg);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  /* Code blocks */
  pre {
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 0.5rem 0 1.5rem;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  pre code {
    font-family: var(--mono);
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* ── Hero extras ── */
  .tagline {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 56ch;
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.9rem;
    background: var(--code-bg);
    color: #cdd6f4;
    padding: 0.875rem 1.25rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .install-block .prompt {
    color: #a6e3a1;
    user-select: none;
  }

  /* ── Demo boxes ── */
  .demo-box {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.25rem 0 2rem;
  }

  .demo-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: #f8fafc;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .demo-content {
    padding: 1.75rem;
  }

  .demo-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .demo-row > * {
    flex: 1;
    min-width: 200px;
  }
</style>
